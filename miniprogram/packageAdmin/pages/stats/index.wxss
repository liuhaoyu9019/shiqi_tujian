/* packageAdmin/pages/stats/index.wxss — 访问统计样式 */

.page {
  min-height: 100vh;
  background: #F5F6FA;
  padding-bottom: 48rpx;
}

.content {
  padding: 24rpx;
}

.error-state {
  text-align: center;
  padding: 80rpx 0;
}

.error-text {
  font-size: 28rpx;
  color: #EF4444;
  display: block;
  margin-bottom: 24rpx;
}

.btn-retry {
  background: #4F6EF7;
  color: #fff;
  font-size: 28rpx;
  border-radius: 12rpx;
  padding: 16rpx 48rpx;
  border: none;
  display: inline-block;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1A1A2E;
  margin-bottom: 16rpx;
  margin-top: 32rpx;
}

.section-title:first-child {
  margin-top: 0;
}

/* 指标卡片 */
.cards-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.card {
  flex: 1;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  text-align: center;
}

.card-num {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #4F6EF7;
}

.card-label {
  display: block;
  font-size: 24rpx;
  color: #6B7280;
  margin-top: 8rpx;
}

/* 7日趋势柱状图 */
.chart-bars {
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
  height: 260rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
}

.bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
}

.bar {
  width: 100%;
  background: linear-gradient(180deg, #4F6EF7, #818CF8);
  border-radius: 8rpx 8rpx 0 0;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  min-height: 4rpx;
  margin-top: auto;
}

.bar-val {
  font-size: 18rpx;
  color: #fff;
  padding-top: 4rpx;
}

.bar-label {
  font-size: 20rpx;
  color: #6B7280;
  margin-top: 8rpx;
}

/* 页面排行 */
.rank-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.rank-item:last-child {
  border-bottom: none;
}

.rank-name {
  width: 160rpx;
  font-size: 26rpx;
  color: #1F2937;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rank-bar-bg {
  flex: 1;
  height: 20rpx;
  background: #F3F4F6;
  border-radius: 10rpx;
  overflow: hidden;
}

.rank-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #4F6EF7, #818CF8);
  border-radius: 10rpx;
}

.rank-count {
  width: 80rpx;
  font-size: 24rpx;
  color: #6B7280;
  text-align: right;
}

/* 24小时分布 */
.chart-columns {
  display: flex;
  align-items: flex-end;
  gap: 4rpx;
  height: 200rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 12rpx;
}

.col-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
  min-width: 0;
}

.col {
  width: 100%;
  background: linear-gradient(180deg, #4F6EF7, #818CF8);
  border-radius: 4rpx 4rpx 0 0;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  min-height: 4rpx;
  margin-top: auto;
}

.col-val {
  font-size: 16rpx;
  color: #fff;
  padding-top: 2rpx;
}

.col-label {
  font-size: 16rpx;
  color: #6B7280;
  margin-top: 4rpx;
  transform: scale(0.85);
}
