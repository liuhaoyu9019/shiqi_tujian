/* packageAdmin/pages/breeds/index.wxss — 品种管理列表样式 */

.page {
  min-height: 100vh;
  background: #F5F6FA;
}

.toolbar {
  padding: 24rpx;
}

.btn-add {
  background: #4F6EF7;
  color: #fff;
  font-size: 28rpx;
  border-radius: 12rpx;
  padding: 16rpx 32rpx;
  border: none;
}

.list {
  padding: 0 24rpx;
}

.list-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.list-cover {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  background: #F3F4F6;
}

.list-info {
  flex: 1;
}

.list-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #1A1A2E;
}

.list-desc {
  display: block;
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.list-actions {
  display: flex;
  gap: 12rpx;
}

.btn-edit {
  background: #EEF2FF;
  color: #4F6EF7;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  border: none;
}

.btn-delete {
  background: #FEE2E2;
  color: #EF4444;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  border: none;
}
