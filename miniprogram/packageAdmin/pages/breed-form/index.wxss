/* packageAdmin/pages/breed-form/index.wxss — 品种表单样式 */

.page {
  min-height: 100vh;
  background: #F5F6FA;
}

.form {
  padding: 24rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #1A1A2E;
  margin-bottom: 12rpx;
}

.form-input {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #1F2937;
}

.form-textarea {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #1F2937;
  min-height: 180rpx;
}

.btn-upload {
  margin-top: 16rpx;
  background: #F3F4F6;
  color: #374151;
  font-size: 26rpx;
  border-radius: 12rpx;
  padding: 16rpx;
  border: 1px dashed #D1D5DB;
}

.preview {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background: #F3F4F6;
  margin-bottom: 32rpx;
}

.btn-submit {
  background: #4F6EF7;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 16rpx;
  padding: 24rpx;
  border: none;
}
