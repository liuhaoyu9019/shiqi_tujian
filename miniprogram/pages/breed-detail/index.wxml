<view class="page">

  <!-- 品种信息加载中 -->
  <view wx:if="{{loading}}" class="init-loading">
    <view class="init-spinner"></view>
    <text class="init-text">加载中...</text>
  </view>

  <view wx:elif="{{error}}" class="empty-wrap" bindtap="loadBreed">
    <text class="empty-icon">⚠️</text>
    <text class="empty-text">{{error}}</text>
    <text class="empty-hint" style="color:#4F6EF7;font-size:24rpx;margin-top:16rpx;">点击重试</text>
  </view>

  <view wx:elif="{{!breed}}" class="empty-wrap">
    <text class="empty-icon">🐾</text>
    <text class="empty-text">品种不存在</text>
  </view>

  <view wx:else class="content">
    <!-- 品种信息头 — 秒出 -->
    <view class="breed-header">
      <view class="back-link" bindtap="onBack">← 返回</view>
      <view class="breed-info-row">
        <image wx:if="{{breed.coverUrl}}" src="{{breed.coverUrl}}" mode="aspectFit" class="breed-cover" />
        <view wx:else class="breed-cover-ph"><text class="ph-icon">🐾</text></view>
        <view class="breed-meta">
          <text class="breed-name">{{breed.name || '未命名'}}</text>
          <text class="breed-desc">{{breed.description || ''}}</text>
          <text class="breed-count">共 {{total || '...'}} 张图片</text>
        </view>
      </view>
    </view>

    <!-- 首屏图片进度条 -->
    <view wx:if="{{showProgress}}" class="progress-wrap">
      <view class="progress-card">
        <view class="progress-icon-wrap">
          <text class="progress-icon">🐾</text>
        </view>
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{imgProgress}}%;">
            <view class="progress-shimmer"></view>
          </view>
        </view>
        <text class="progress-text">图片加载中 <text class="progress-num">{{imgProgress}}</text>%</text>
        <text class="progress-hint">首次加载较慢，请耐心等待</text>
      </view>
    </view>

    <!-- 隐藏预载区：首屏图片后台加载 -->
    <view class="preload-zone" aria-hidden="true">
      <block wx:for="{{images}}" wx:key="id">
        <image wx:if="{{item.thumbnailUrl}}" src="{{item.thumbnailUrl}}" mode="aspectFit" class="preload-img" bindload="onImgLoad" binderror="onImgError" />
      </block>
    </view>

    <!-- 图片网格：首屏就绪后渲染 -->
    <view wx:if="{{imgReady}}" class="img-grid grid-show">
      <view wx:for="{{images}}" wx:key="id" class="img-card" data-id="{{item.id}}" bindtap="onImageTap">
        <image wx:if="{{item.thumbnailUrl}}" src="{{item.thumbnailUrl}}" mode="{{item.isGif ? 'aspectFit' : 'scaleToFill'}}" class="img-thumb" />
        <view wx:else class="img-ph"><text>🐾</text></view>
        <view class="img-name-wrap"><text class="img-name">{{item.name || ''}}</text></view>
      </view>
    </view>

    <!-- 图片加载后的空态 -->
    <view wx:if="{{imgReady && images.length === 0}}" class="empty-wrap">
      <text class="empty-icon">🖼️</text>
      <text class="empty-text">暂无品种图片</text>
    </view>

    <!-- 底部加载状态 -->
    <view wx:if="{{imgReady && images.length > 0}}" class="bottom-tip">
      <view wx:if="{{loadingMore}}" class="bt-loading">
        <view class="bt-spinner" />
        <text>加载中…</text>
      </view>
      <view wx:elif="{{hasMore}}" class="bt-more">上滑加载更多</view>
      <view wx:else class="bt-done">— 已展示全部 {{total}} 张 —</view>
    </view>
  </view>

  <!-- 图片详情卡片 -->
  <view wx:if="{{detailImg}}" class="overlay" bindtap="onCloseDetail">
    <view class="detail-card" catchtap="">
      <image wx:if="{{detailImgSrc}}" src="{{detailImgSrc}}" mode="widthFix" class="detail-img" />
      <view wx:else class="detail-ph"><text>🐾</text></view>
      <view class="detail-info">
        <text class="detail-name">{{detailImg.name || '未命名'}}</text>
        <text class="detail-desc">{{detailDesc}}</text>
      </view>
      <view class="detail-close" bindtap="onCloseDetail">✕</view>
    </view>
  </view>

</view>
