/* pages/admin/dashboard.wxss */
page { background: #F5F6FA; }
.page { min-height: 100vh; }

/* 鉴权 */
.auth-wrap { display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 48rpx; }
.auth-card { width: 100%; max-width: 500rpx; background: #FFFFFF; border-radius: 24rpx; padding: 48rpx 32rpx; text-align: center; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08); }
.auth-title { display: block; font-size: 36rpx; font-weight: bold; color: #1A1A2E; margin-bottom: 32rpx; }
.auth-input { width: 100%; border: 2rpx solid #E5E7EB; border-radius: 16rpx; padding: 20rpx; font-size: 28rpx; text-align: center; box-sizing: border-box; margin-bottom: 24rpx; }
.auth-btn { width: 100%; background: #4F6EF7; color: #FFFFFF; border-radius: 16rpx; padding: 20rpx; font-size: 28rpx; border: none; }
.auth-err { display: block; color: #EF4444; font-size: 24rpx; margin-top: 16rpx; }

/* 骨架 */
.loading-wrap { display: flex; flex-wrap: wrap; gap: 24rpx; padding: 24rpx; }
.sk-card { flex: 1; min-width: 280rpx; height: 160rpx; background: #E5E7EB; border-radius: 24rpx; }

/* 卡片 */
.cards { display: flex; flex-wrap: wrap; gap: 24rpx; padding: 24rpx; }
.card { flex: 1; min-width: 280rpx; background: #FFFFFF; border-radius: 24rpx; padding: 40rpx 32rpx; text-align: center; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.card-num { display: block; font-size: 56rpx; font-weight: bold; color: #4F6EF7; }
.card-label { display: block; font-size: 24rpx; color: #6B7280; margin-top: 8rpx; }
