page { background: #F5F6FA; }
.page { min-height: 100vh; padding-bottom: 24rpx; }

.hero { position: relative; height: 420rpx; overflow: hidden; margin-bottom: 24rpx; }
.hero-swiper { width: 100%; height: 100%; }
.hero-bg { width: 100%; height: 100%; }
.hero-mask { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.35); }
.hero-content { position: relative; z-index: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; padding: 32rpx; }
.hero-title { display: block; font-size: 40rpx; font-weight: bold; color: #FFFFFF; text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3); }
.hero-desc { display: block; font-size: 28rpx; color: rgba(255,255,255,0.9); margin-top: 12rpx; text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.3); }
.hero-badge { display: inline-block; background: rgba(255,255,255,0.2); color: #FFFFFF; font-size: 22rpx; padding: 8rpx 20rpx; border-radius: 24rpx; margin-top: 16rpx; backdrop-filter: blur(4rpx); }

/* API 请求中：简洁转圈，不出现卡片轮廓 */
.init-loading { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 160rpx 48rpx; }
.init-spinner { width: 56rpx; height: 56rpx; border: 4rpx solid #E5E7EB; border-top-color: #4F6EF7; border-radius: 50%; animation: spin 0.8s linear infinite; margin-bottom: 24rpx; }
@keyframes spin { to { transform: rotate(360deg); } }
.init-text { font-size: 26rpx; color: #9CA3AF; }

.empty-wrap { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 120rpx 48rpx; }
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; color: #9CA3AF; margin-bottom: 16rpx; text-align: center; }
.empty-hint { font-size: 24rpx; color: #4F6EF7; }

/* ====== 图片加载进度条 ====== */
.progress-wrap { display: flex; justify-content: center; padding: 24rpx 48rpx 32rpx; }
.progress-card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx 36rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(79,110,247,0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
}
.progress-icon-wrap {
  width: 88rpx; height: 88rpx;
  background: linear-gradient(135deg, #EEF0FF 0%, #E8EAFF 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
  animation: paw-bounce 0.6s ease-in-out infinite alternate;
}
@keyframes paw-bounce {
  from { transform: translateY(0); }
  to   { transform: translateY(-10rpx); }
}
.progress-icon { font-size: 48rpx; }
.progress-bar {
  width: 100%; height: 12rpx;
  background: #EEF0F4;
  border-radius: 6rpx;
  overflow: hidden;
  position: relative;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4F6EF7 0%, #7C5CFC 50%, #A78BFA 100%);
  border-radius: 6rpx;
  transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}
.progress-shimmer {
  position: absolute; top: 0; left: -100%; width: 100%; height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
  animation: shimmer-move 1.6s ease-in-out infinite;
}
@keyframes shimmer-move {
  0%   { left: -100%; }
  100% { left: 200%; }
}
.progress-text { font-size: 26rpx; color: #4B5563; margin-top: 20rpx; font-weight: 500; }
.progress-num  { font-size: 32rpx; color: #4F6EF7; font-weight: 700; }
.progress-hint { font-size: 22rpx; color: #B0B7C3; margin-top: 10rpx; }

/* ====== 隐藏预载区 ====== */
.preload-zone { position: fixed; top: -9999rpx; left: -9999rpx; width: 1rpx; height: 1rpx; opacity: 0; pointer-events: none; overflow: hidden; }
.preload-img { width: 1rpx; height: 1rpx; }

/* ====== 图片网格 ====== */
.grid { display: flex; flex-wrap: wrap; justify-content: space-between; padding: 0 24rpx; }
.grid-show { animation: gridFadeIn 0.5s ease-out both; }
@keyframes gridFadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to   { opacity: 1; transform: translateY(0); }
}
.card { width: calc(50% - 12rpx); background: #FFFFFF; border-radius: 24rpx; overflow: hidden; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); margin-bottom: 16rpx; }
.card-img { width: 100%; height: 300rpx; background: #FFFFFF; padding: 20rpx; box-sizing: border-box; }
.card-ph { width: 100%; height: 280rpx; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #EEF0FF, #E8EAFF); }
.ph-icon { font-size: 80rpx; }
.card-info { padding: 20rpx 24rpx; }
.card-name { font-size: 28rpx; font-weight: 600; color: #1A1A2E; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-bottom: 8rpx; }
.card-desc { font-size: 24rpx; color: #6B7280; line-height: 1.5; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; word-break: break-all; }

.disclaimer { padding: 32rpx 40rpx; text-align: center; }
.disclaimer-text { font-size: 22rpx; color: #B0B7C3; line-height: 1.8; }
