page { background: #F5F6FA; }
.page { min-height: 100vh; padding-bottom: 24rpx; }

.hero { position: relative; height: 420rpx; overflow: hidden; margin-bottom: 24rpx; }
.hero-bg { width: 100%; height: 100%; position: absolute; top: 0; left: 0; background: #2D2D3A; }
.hero-mask { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.35); }
.hero-content { position: relative; z-index: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; padding: 32rpx; }
.hero-title { display: block; font-size: 40rpx; font-weight: bold; color: #FFFFFF; text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3); }
.hero-desc { display: block; font-size: 28rpx; color: rgba(255,255,255,0.9); margin-top: 12rpx; text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.3); }
.hero-badge { display: inline-block; background: rgba(255,255,255,0.2); color: #FFFFFF; font-size: 22rpx; padding: 8rpx 20rpx; border-radius: 24rpx; margin-top: 16rpx; backdrop-filter: blur(4rpx); }

.loading-wrap { display: flex; flex-wrap: wrap; gap: 16rpx; padding: 0 24rpx; }
.sk-block { width: calc(50% - 8rpx); height: 320rpx; background: #E5E7EB; border-radius: 24rpx; }

.empty-wrap { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 120rpx 48rpx; }
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; color: #9CA3AF; margin-bottom: 16rpx; text-align: center; }
.empty-hint { font-size: 24rpx; color: #4F6EF7; }

.grid { display: flex; flex-wrap: wrap; gap: 16rpx; padding: 0 24rpx; }
.card { width: calc(50% - 8rpx); background: #FFFFFF; border-radius: 24rpx; overflow: hidden; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.card-img { width: 100%; height: 260rpx; background: #F9FAFB; padding: 20rpx; box-sizing: border-box; }
.card-ph { width: 100%; height: 280rpx; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #EEF0FF, #E8EAFF); }
.ph-icon { font-size: 80rpx; }
.card-info { padding: 20rpx 24rpx; }
.card-name { font-size: 28rpx; font-weight: 600; color: #1A1A2E; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-bottom: 8rpx; }
.card-desc { font-size: 24rpx; color: #6B7280; line-height: 1.5; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; word-break: break-all; }

.disclaimer { padding: 32rpx 40rpx; text-align: center; }
.disclaimer-text { font-size: 22rpx; color: #B0B7C3; line-height: 1.8; }
